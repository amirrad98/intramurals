{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "leagueflow/knockout-bracket",
	"title": "Knockout Bracket",
	"category": "widgets",
	"icon": "editor-table",
	"description": "Display a knockout bracket grouped by round.",
	"textdomain": "leagueflow",
	"attributes": {
		"sport": {
			"type": "string",
			"default": ""
		},
		"competition": {
			"type": "string",
			"default": ""
		},
		"season": {
			"type": "string",
			"default": ""
		},
		"league_level": {
			"type": "string",
			"default": ""
		}
	},
	"editorScript": "leagueflow-blocks",
	"editorStyle": "leagueflow-editor",
	"style": "leagueflow-frontend"
}
