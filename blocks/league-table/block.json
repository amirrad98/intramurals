{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "leagueflow/league-table",
	"title": "League Table",
	"category": "widgets",
	"icon": "editor-table",
	"description": "Display an auto-calculated table for a competition and season.",
	"textdomain": "leagueflow",
	"attributes": {
		"sport": {
			"type": "string",
			"default": ""
		},
		"competition": {
			"type": "string",
			"default": ""
		},
		"season": {
			"type": "string",
			"default": ""
		},
		"league_level": {
			"type": "string",
			"default": ""
		},
		"show_logos": {
			"type": "boolean",
			"default": true
		}
	},
	"editorScript": "leagueflow-blocks",
	"editorStyle": "leagueflow-editor",
	"style": "leagueflow-frontend"
}
