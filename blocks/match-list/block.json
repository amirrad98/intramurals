{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "leagueflow/match-list",
	"title": "Match List",
	"category": "widgets",
	"icon": "calendar-alt",
	"description": "Display fixtures or results.",
	"textdomain": "leagueflow",
	"attributes": {
		"sport": {
			"type": "string",
			"default": ""
		},
		"competition": {
			"type": "string",
			"default": ""
		},
		"season": {
			"type": "string",
			"default": ""
		},
		"league_level": {
			"type": "string",
			"default": ""
		},
		"status": {
			"type": "string",
			"default": ""
		},
		"limit": {
			"type": "number",
			"default": 10
		}
	},
	"editorScript": "leagueflow-blocks",
	"editorStyle": "leagueflow-editor",
	"style": "leagueflow-frontend"
}
